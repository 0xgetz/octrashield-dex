{
  "name": "mock-octra-sdk",
  "version": "0.1.0",
  "description": "Mock implementations of OctraShield DEX SDK clients for testing — no network calls, deterministic data",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
