{
  "name": "@octrashield/dex-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for OctraShield DEX with client-side HFHE encryption, OCS01 transactions, and React hooks",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/esm/hooks/index.js",
      "require": "./dist/cjs/hooks/index.js",
      "types": "./dist/types/hooks/index.d.ts"
    },
    "./core": {
      "import": "./dist/esm/core/index.js",
      "require": "./dist/cjs/core/index.js",
      "types": "./dist/types/core/index.d.ts"
    },
    "./clients": {
      "import": "./dist/esm/clients/index.js",
      "require": "./dist/cjs/clients/index.js",
      "types": "./dist/types/clients/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "dev": "tsc -p tsconfig.esm.json --watch",
    "lint": "biome check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "prepare": "husky",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "husky": "^9.0.0",
    "lefthook": "^1.7.0",
    "@biomejs/biome": "^1.9.0"
  },
  "keywords": [
    "octrashield",
    "dex",
    "defi",
    "fhe",
    "hfhe",
    "encrypted",
    "amm",
    "privacy",
    "octra-network",
    "ocs01"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
