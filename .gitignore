# ---- Environment ----
.env
.env.*
!.env.example

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Docker ----
docker-compose.override.yml

# ---- Misc ----
*.log
tmp/
.cache/
