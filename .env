# .env configuration file

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_db_name

# API Configuration
API_KEY=your_api_key
API_SECRET=your_api_secret

# App Configuration
APP_ENV=development
APP_PORT=3000
DEBUG=True
LOG_LEVEL=info

# Other Configuration
OTHER_CONFIG=value