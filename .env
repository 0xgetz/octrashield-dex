# OctraShield DEX — Environment Configuration
# Never commit .env to version control.

# ─── Network ────────────────────────────────────────────────────────────────

# Target network: 'octra-testnet' | 'octra-mainnet'
VITE_NETWORK=octra-testnet

# Octra Network RPC endpoint
OCTRA_RPC_URL=https://octra.network

# ─── Contract Addresses (set after deployment) ───────────────────────────────

# OctraShieldFactory contract address
VITE_FACTORY_ADDRESS=

# OctraShieldRouter contract address
VITE_ROUTER_ADDRESS=

# AI Fee Engine contract address
VITE_AI_ENGINE_ADDRESS=

# ShieldToken (default LP token) contract address
VITE_SHIELD_TOKEN_ADDRESS=

# Octra network address
OCTRA_ADDRESS=oct25CVMgbie4Cu6zpAgxpiHy1odbf8GszFxrSqSdBMknx6

# ─── Deployment Configuration ──────────────────────────────────────────────

# Deployer private key (keep this secret!)
DEPLOYER_PRIVATE_KEY=YH0eGwPBlu0L+PlrZ5xS6v9NLKMVWg78FrLi1lBoA5E=

# ─── App Settings ────────────────────────────────────────────────────────────

# App title shown in the browser tab
VITE_APP_TITLE=OctraShield DEX

# Enable testnet faucet link in the UI (true | false)
VITE_SHOW_FAUCET=true

# Faucet URL for the devnet
VITE_FAUCET_URL=https://faucet.octra.org

# Block explorer base URL
VITE_EXPLORER_URL=https://scan.octra.org

# ─── HFHE / Crypto Settings ──────────────────────────────────────────────────

# Number of Newton-Raphson iterations for encrypted division (higher = more accurate, slower)
VITE_NR_ITERATIONS=6

# ─── Build / CI ──────────────────────────────────────────────────────────────

# Set to 'production' for production builds
NODE_ENV=development

# ─── Database Configuration (placeholder) ────────────────────────────────────

DB_HOST=localhost
DB_PORT=5432
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_db_name

# ─── API Configuration (placeholder) ─────────────────────────────────────────

API_KEY=your_api_key
API_SECRET=your_api_secret

# ─── App Configuration ───────────────────────────────────────────────────────

APP_ENV=development
APP_PORT=3000
DEBUG=True
LOG_LEVEL=info
